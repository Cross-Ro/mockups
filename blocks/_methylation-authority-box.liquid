{%- liquid
  assign feature_count = 0
  for child in block.blocks
    if child.id contains '_f_'
      assign feature_count = feature_count | plus: 1
    endif
  endfor
-%}

<div class="methylation-hero__authority" {{ block.shopify_attributes }}>

  <div class="methylation-hero__authority-header">
    {%- for child in block.blocks -%}
      {%- if child.id contains '_ahead' or child.id contains '_abody' -%}
        {% render child, section: section %}
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if feature_count > 0 -%}
    <div class="methylation-hero__authority-features-group">
      <div class="methylation-hero__features" data-feature-count="{{ feature_count }}">
        {%- for child in block.blocks -%}
          {%- if child.id contains '_f_' -%}
            {% render child, section: section %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <div class="methylation-hero__authority-cta-group">
    {%- for child in block.blocks -%}
      {%- if child.id contains '_acta' -%}
        {% render child, section: section %}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Authority box",
  "settings": [],
  "blocks": [
    { "type": "_methylation-authority-headline" },
    { "type": "_methylation-authority-body" },
    { "type": "_methylation-authority-feature" },
    { "type": "_methylation-authority-cta" }
  ],
  "presets": [
    {
      "name": "Authority box"
    }
  ]
}
{% endschema %}
