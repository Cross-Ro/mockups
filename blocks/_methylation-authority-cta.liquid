{%- liquid
  assign label = block.settings.label | default: 'Decode My Methylation'
  assign link  = block.settings.link  | default: '#'
-%}

{%- if label != blank -%}
  <a
    href="{{ link }}"
    class="methylation-hero__authority-cta"
    data-cta="methylation-hero-authority"
    {{ block.shopify_attributes }}
  >
    {{ label | escape }}
  </a>
{%- endif -%}

{% schema %}
{
  "name": "Authority CTA",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Button label",
      "default": "Decode My Methylation"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button link"
    }
  ]
}
{% endschema %}
