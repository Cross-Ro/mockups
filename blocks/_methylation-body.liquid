{%- if block.settings.text != blank -%}
  <div class="methylation-hero__body" {{ block.shopify_attributes }}>
    {{ block.settings.text }}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Body text",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    }
  ]
}
{% endschema %}
