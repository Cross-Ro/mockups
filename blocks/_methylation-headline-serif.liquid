{% doc %}
  Renders the display (Oswald) headline for the methylation hero.

  @param {string} [section_id] - Owning section id, used to make the anchor id unique per instance.
{% enddoc %}

{%- if block.settings.text != blank -%}
  <h1
    id="methylation-hero-heading-{{ section_id }}"
    class="methylation-hero__headline-serif"
    {{ block.shopify_attributes }}
  >
    {{ block.settings.text | escape }}
  </h1>
{%- endif -%}

{% schema %}
{
  "name": "Headline (display)",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Decode Your Methylation"
    }
  ]
}
{% endschema %}
