{%- liquid
  assign mobile_layout = block.settings.mobile_layout | default: 'stacked'
  assign loop_enabled  = block.settings.mobile_image_loop
  assign autoplay_on   = block.settings.mobile_image_autoplay
  assign autoplay_ms   = block.settings.mobile_image_autoplay_delay | default: 4000
  assign child_count   = block.blocks.size
  assign column_class  = 'methylation-hero__column'
  if mobile_layout == 'swiper'
    assign column_class = 'methylation-hero__column methylation-hero__column--swiper-mobile'
  endif
-%}

<div class="{{ column_class }}" {{ block.shopify_attributes }}>
  {%- if mobile_layout == 'swiper' and child_count > 0 -%}

    {%- comment -%}Stacked layout — visible on desktop only{%- endcomment -%}
    <div class="methylation-hero__column-stack">
      {%- for child in block.blocks -%}
        {%- if forloop.first -%}
          {% render child, section: section, role: 'hero', index: 0 %}
        {%- else -%}
          {% render child, section: section, role: 'thumb', index: forloop.index0 %}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%}Mobile carousel — native CSS scroll-snap, no JS dependency{%- endcomment -%}
    <div class="methylation-hero__column-swiper">
      <div class="methylation-hero__scroller" role="region" aria-label="Product images carousel" tabindex="0">
        {%- for child in block.blocks -%}
          <div class="methylation-hero__slide">
            {% render child, section: section, role: 'swiper', index: forloop.index0 %}
          </div>
        {%- endfor -%}
      </div>
    </div>

  {%- else -%}
    {%- for child in block.blocks -%}
      {% render child, section: section %}
    {%- endfor -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Hero column",
  "settings": [
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        { "value": "stacked", "label": "Stacked" },
        { "value": "swiper",  "label": "Swiper carousel" }
      ],
      "default": "stacked"
    },
    {
      "type": "header",
      "content": "Mobile carousel (when swiper)"
    },
    {
      "type": "checkbox",
      "id": "mobile_image_loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mobile_image_autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "mobile_image_autoplay_delay",
      "label": "Autoplay delay",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "unit": "ms",
      "default": 4000
    }
  ],
  "blocks": [
    { "type": "_methylation-image" },
    { "type": "_methylation-details" },
    { "type": "_methylation-authority-box" },
    { "type": "_methylation-eyebrow" },
    { "type": "_methylation-headline-serif" },
    { "type": "_methylation-headline-script" },
    { "type": "_methylation-tagline" },
    { "type": "_methylation-body" },
    { "type": "_methylation-value-cards" },
    { "type": "_methylation-price" },
    { "type": "_methylation-cta" },
    { "type": "_methylation-payment-terms" }
  ],
  "presets": [
    { "name": "Hero column" }
  ]
}
{% endschema %}
