{%- liquid
  assign all_products_valid = true
  assign variant_ids = ''
  assign products_array = ''

  for i in (1..5)
    assign setting_key = 'product_' | append: i
    assign product = section.settings[setting_key]

    if product == blank
      assign all_products_valid = false
    else
      assign variant = product.selected_or_first_available_variant
      if variant == blank
        assign all_products_valid = false
      else
        if variant_ids == ''
          assign variant_ids = variant.id | prepend: '['
        else
          assign variant_ids = variant_ids | append: ',' | append: variant.id
        endif
      endif
    endif
  endfor

  unless variant_ids == ''
    assign variant_ids = variant_ids | append: ']'
  endunless

  assign cta_disabled = false
  unless all_products_valid
    assign cta_disabled = true
  endunless
-%}

<div
  class="bundle-section section spacing-style color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="bundle-section-{{ section.id }}"
>
  <div class="bundle-section__inner page-width">

    {%- if section.settings.headline != blank -%}
      <h2 class="bundle-section__headline">{{ section.settings.headline | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.percentage_display != blank -%}
      <p class="bundle-section__savings-label">{{ section.settings.percentage_display | escape }}</p>
    {%- endif -%}

    {%- if request.design_mode and cta_disabled -%}
      <div class="bundle-section__editor-warning" role="alert" aria-live="polite">
        Bundle requires 5 products — please fill all product pickers and ensure each product has an available variant.
      </div>
    {%- endif -%}

    <bundle-cta-component
      data-variants="{{ variant_ids | json }}"
      data-bundle-id="{{ section.id }}"
      data-state="idle"
    >
      <ul class="bundle-section__grid" aria-label="{{ section.settings.headline | default: 'Bundle products' | escape }}">
        {%- for i in (1..5) -%}
          {%- assign setting_key = 'product_' | append: i -%}
          {%- assign product = section.settings[setting_key] -%}
          {%- if product != blank -%}
            {%- render 'bundle-product-card', product: product -%}
          {%- else -%}
            <li class="bundle-product-card bundle-product-card--empty" aria-hidden="true">
              {{ 'product-1' | placeholder_svg_tag: 'bundle-product-card__image bundle-product-card__image--placeholder' }}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      <div class="bundle-section__cta-wrapper">
        <button
          type="button"
          class="bundle-section__cta button"
          {% if cta_disabled %}disabled aria-disabled="true"{% endif %}
          data-testid="bundle-cta-button"
        >
          <span class="bundle-section__cta-label">{{ 'Add bundle to cart' }}</span>
          <span class="bundle-section__cta-loading" aria-hidden="true"></span>
        </button>

        <p class="bundle-section__error-message" role="alert" aria-live="assertive" hidden></p>
      </div>
    </bundle-cta-component>

  </div>
</div>

{% stylesheet %}
  .bundle-section {
    padding-block-start: var(--padding-block-start, 0px);
    padding-block-end: var(--padding-block-end, 0px);
  }

  .bundle-section__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }

  .bundle-section__headline {
    font: var(--font-heading--family, var(--font-primary--family));
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    color: var(--color-foreground);
    margin: 0;
  }

  .bundle-section__savings-label {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-foreground);
    opacity: 0.75;
    margin: 0;
  }

  .bundle-section__editor-warning {
    width: 100%;
    padding: 0.75rem 1rem;
    background-color: #fff3cd;
    border: 1px solid #ffc107;
    border-radius: 4px;
    color: #856404;
    font-size: 0.875rem;
    text-align: left;
  }

  .bundle-section__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    width: 100%;

    @media screen and (min-width: 750px) {
      grid-template-columns: repeat(5, 1fr);
      gap: 1rem;
    }
  }

  .bundle-product-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
  }

  .bundle-product-card--empty {
    opacity: 0.35;
  }

  .bundle-product-card__image-wrapper {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--media-border-radius, 4px);
    background-color: var(--color-background-secondary, #f5f5f5);
  }

  .bundle-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }

  .bundle-product-card__image-link:hover .bundle-product-card__image {
    transform: scale(1.03);
  }

  .bundle-product-card__image--placeholder {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.4;
  }

  .bundle-product-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .bundle-product-card__title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-foreground);
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }

  .bundle-product-card__title:hover {
    text-decoration: underline;
  }

  .bundle-product-card__price {
    font-size: 0.875rem;
    color: var(--color-foreground);
    margin: 0;
    opacity: 0.8;
  }

  .bundle-section__cta-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
  }

  .bundle-section__cta {
    width: 100%;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;

    @media screen and (min-width: 750px) {
      width: auto;
      min-width: 320px;
      max-width: 320px;
    }
  }

  .bundle-section__cta[disabled],
  .bundle-section__cta[aria-disabled="true"] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Loading spinner — shown when data-state="busy" on host */
  bundle-cta-component[data-state="busy"] .bundle-section__cta-loading {
    display: inline-block;
    width: 1em;
    height: 1em;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: bundle-spin 0.6s linear infinite;
    flex-shrink: 0;
  }

  bundle-cta-component[data-state="idle"] .bundle-section__cta-loading,
  bundle-cta-component[data-state="error"] .bundle-section__cta-loading {
    display: none;
  }

  @keyframes bundle-spin {
    to { transform: rotate(360deg); }
  }

  /* Error state */
  bundle-cta-component[data-state="error"] .bundle-section__error-message {
    display: block;
  }

  .bundle-section__error-message {
    font-size: 0.875rem;
    color: var(--color-error, #c0392b);
    max-width: 320px;
    text-align: center;
  }
{% endstylesheet %}

