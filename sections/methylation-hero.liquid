{%- liquid
  assign padding_top_desktop    = section.settings.container_padding_top    | default: 48
  assign padding_bottom_desktop = section.settings.container_padding_bottom | default: 48
  assign padding_top_mobile     = section.settings.container_padding_top_mobile    | default: 24
  assign padding_bottom_mobile  = section.settings.container_padding_bottom_mobile | default: 24
-%}

<style>
  #shopify-section-{{ section.id }} .methylation-hero {
    --padding-top: {{ padding_top_mobile }}px;
    --padding-bottom: {{ padding_bottom_mobile }}px;
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .methylation-hero {
      --padding-top: {{ padding_top_desktop }}px;
      --padding-bottom: {{ padding_bottom_desktop }}px;
    }
  }
</style>

<section
  class="methylation-hero color-{{ section.settings.color_scheme }}"
  aria-labelledby="methylation-hero-heading-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="methylation-hero__inner">
    {% content_for 'blocks' %}
  </div>
</section>

{% schema %}
{
  "name": "Methylation Hero",
  "tag": "div",
  "class": "methylation-hero-section-wrapper",
  "max_blocks": 50,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding (desktop)"
    },
    {
      "type": "range",
      "id": "container_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "container_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Padding (mobile)"
    },
    {
      "type": "range",
      "id": "container_padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "container_padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "blocks": [
    { "type": "methylation-hero-column" }
  ],
  "presets": [
    {
      "name": "Methylation Hero",
      "blocks": {
        "col_left": {
          "type": "methylation-hero-column",
          "settings": { "mobile_layout": "swiper" },
          "blocks": {
            "img_1": { "type": "_methylation-image" },
            "img_2": { "type": "_methylation-image" },
            "img_3": { "type": "_methylation-image" },
            "img_4": { "type": "_methylation-image" },
            "img_5": { "type": "_methylation-image" }
          },
          "block_order": ["img_1", "img_2", "img_3", "img_4", "img_5"]
        },
        "col_right": {
          "type": "methylation-hero-column",
          "blocks": {
            "eyebrow":         { "type": "_methylation-eyebrow" },
            "headline_serif":  { "type": "_methylation-headline-serif" },
            "headline_script": { "type": "_methylation-headline-script" },
            "tagline":         { "type": "_methylation-tagline" },
            "body":            { "type": "_methylation-body" },
            "value_cards": {
              "type": "_methylation-value-cards",
              "blocks": {
                "vc_1": { "type": "_methylation-value-card" },
                "vc_2": { "type": "_methylation-value-card" },
                "vc_3": { "type": "_methylation-value-card" }
              },
              "block_order": ["vc_1","vc_2","vc_3"]
            },
            "price":           { "type": "_methylation-price" },
            "cta":             { "type": "_methylation-cta" },
            "payment_terms":   { "type": "_methylation-payment-terms" },
            "authority_box": {
              "type": "_methylation-authority-box",
              "blocks": {
                "ahead": { "type": "_methylation-authority-headline" },
                "abody": { "type": "_methylation-authority-body" },
                "f_1":   { "type": "_methylation-authority-feature" },
                "f_2":   { "type": "_methylation-authority-feature" },
                "f_3":   { "type": "_methylation-authority-feature" },
                "f_4":   { "type": "_methylation-authority-feature" },
                "f_5":   { "type": "_methylation-authority-feature" },
                "acta":  { "type": "_methylation-authority-cta" }
              },
              "block_order": ["ahead","abody","f_1","f_2","f_3","f_4","f_5","acta"]
            }
          },
          "block_order": ["eyebrow","headline_serif","headline_script","tagline","body","value_cards","price","cta","payment_terms","authority_box"]
        }
      },
      "block_order": ["col_left", "col_right"]
    }
  ]
}
{% endschema %}
