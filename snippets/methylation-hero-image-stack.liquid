{%- doc -%}
  Renders the image stack for the methylation-hero section.

  Desktop: 1 hero image + 2×2 supporting grid (display: grid, shown ≥1024px).
  Mobile:  horizontal <carousel-swiper> with all images (shown <1024px).

  DOM duplication strategy: image markup is emitted into two wrappers
  (.methylation-hero__images--grid and .methylation-hero__images--swiper).
  CSS toggles display between them. Browser deduplicates image requests.

  @param {object} section - The Shopify section object
{%- enddoc -%}

{%- liquid
  assign image_blocks = section.blocks | where: 'type', 'image'
  assign image_count  = image_blocks | size
  assign loop_enabled = section.settings.mobile_image_loop
  assign autoplay_on  = section.settings.mobile_image_autoplay
  assign autoplay_ms  = section.settings.mobile_image_autoplay_delay | default: 4000
-%}

<div class="methylation-hero__images">

  {%- comment -%}——————————————————————————————————————————
    DESKTOP GRID (hidden on mobile via CSS)
  ——————————————————————————————————————————{%- endcomment -%}
  <div class="methylation-hero__images--grid" aria-hidden="false">
    {%- if image_count > 0 -%}
      {%- assign hero_block = image_blocks | first -%}
      <div class="methylation-hero__image-wrap methylation-hero__image-wrap--hero" {{ hero_block.shopify_attributes }}>
        {%- if hero_block.settings.image != blank -%}
          {%- assign hero_alt = hero_block.settings.image.alt | escape | default: hero_block.settings.alt | escape | default: '' -%}
          {{
            hero_block.settings.image
            | image_url: width: 1400
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              alt: hero_alt,
              class: 'methylation-hero__image',
              widths: '400, 700, 900, 1400',
              sizes: '(min-width: 1024px) 700px, 100vw'
          }}
        {%- else -%}
          <div class="methylation-hero__image-placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'methylation-hero__image methylation-hero__image--placeholder' }}
            <span class="methylation-hero__image-placeholder-label">Hero image · 700×700</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if image_count > 1 -%}
      <div class="methylation-hero__image-grid-layout">
        {%- for block in image_blocks offset: 1 -%}
          <div class="methylation-hero__image-wrap methylation-hero__image-wrap--thumb" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {%- assign thumb_alt = block.settings.image.alt | escape | default: block.settings.alt | escape | default: '' -%}
              {{
                block.settings.image
                | image_url: width: 700
                | image_tag:
                  loading: 'lazy',
                  alt: thumb_alt,
                  class: 'methylation-hero__image',
                  widths: '200, 350, 700',
                  sizes: '(min-width: 1024px) 345px, 50vw'
              }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%}——————————————————————————————————————————
    MOBILE SWIPER (hidden on desktop via CSS)
  ——————————————————————————————————————————{%- endcomment -%}
  <div class="methylation-hero__images--swiper" aria-hidden="true">
    <carousel-swiper>
      <script type="application/json">
        {
          "slidesPerView": 1.1,
          "spaceBetween": 12,
          "grabCursor": true,
          "loop": {{ loop_enabled | json }},
          "autoplay": {% if autoplay_on %}{ "delay": {{ autoplay_ms }}, "disableOnInteraction": true }{% else %}false{% endif %},
          "pagination": true
        }
      </script>

      <div class="swiper">
        <div class="swiper-wrapper">
          {%- for block in image_blocks -%}
            <div class="swiper-slide">
              <div class="methylation-hero__image-wrap methylation-hero__image-wrap--swiper">
                {%- if block.settings.image != blank -%}
                  {%- assign slide_alt = block.settings.image.alt | escape | default: block.settings.alt | escape | default: '' -%}
                  {%- if forloop.first -%}
                    {{
                      block.settings.image
                      | image_url: width: 900
                      | image_tag:
                        loading: 'eager',
                        fetchpriority: 'high',
                        alt: slide_alt,
                        class: 'methylation-hero__image',
                        widths: '440, 600, 900',
                        sizes: '100vw'
                    }}
                  {%- else -%}
                    {{
                      block.settings.image
                      | image_url: width: 900
                      | image_tag:
                        loading: 'lazy',
                        alt: slide_alt,
                        class: 'methylation-hero__image',
                        widths: '440, 600, 900',
                        sizes: '100vw'
                    }}
                  {%- endif -%}
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if image_count > 1 -%}
          <div class="methylation-hero__swiper-pagination swiper-pagination"></div>
        {%- endif -%}
      </div>
    </carousel-swiper>
  </div>

</div>
