{%- doc -%}
  Renders the product copy column for the methylation-hero section.
  Blocks are grouped into logical wrappers (header / description /
  value-box / price-cta) to mirror the Figma "What You Get Box" + copy.

  @param {object} section - The Shopify section object
{%- enddoc -%}

{%- liquid
  assign eyebrow_block        = section.blocks | where: 'type', 'eyebrow'         | first
  assign headline_serif_block = section.blocks | where: 'type', 'headline_serif'  | first
  assign headline_script_block = section.blocks | where: 'type', 'headline_script' | first
  assign tagline_block        = section.blocks | where: 'type', 'tagline'         | first
  assign body_block           = section.blocks | where: 'type', 'body'            | first
  assign value_card_blocks    = section.blocks | where: 'type', 'value_card'
  assign price_block          = section.blocks | where: 'type', 'price'           | first
  assign cta_block            = section.blocks | where: 'type', 'cta'             | first
  assign value_card_count     = value_card_blocks | size
-%}

<div class="methylation-hero__copy">

  {%- comment -%}—— GROUP 1 · Header (eyebrow + headlines + tagline) ——{%- endcomment -%}
  <div class="methylation-hero__header-group">
    {%- if eyebrow_block and eyebrow_block.settings.text != blank -%}
      <p class="methylation-hero__eyebrow" {{ eyebrow_block.shopify_attributes }}>
        {{ eyebrow_block.settings.text | escape }}
      </p>
    {%- endif -%}

    {%- if headline_serif_block and headline_serif_block.settings.text != blank -%}
      <h1
        id="methylation-hero-heading"
        class="methylation-hero__headline-serif"
        {{ headline_serif_block.shopify_attributes }}
      >
        {{ headline_serif_block.settings.text | escape }}
      </h1>
    {%- endif -%}

    {%- if headline_script_block and headline_script_block.settings.text != blank -%}
      <p class="methylation-hero__headline-script" {{ headline_script_block.shopify_attributes }}>
        {{ headline_script_block.settings.text | escape }}
      </p>
    {%- endif -%}

    {%- if tagline_block and tagline_block.settings.text != blank -%}
      <div class="methylation-hero__tagline" {{ tagline_block.shopify_attributes }}>
        {{ tagline_block.settings.text }}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%}—— GROUP 2 · Description body ——{%- endcomment -%}
  {%- if body_block and body_block.settings.text != blank -%}
    <div class="methylation-hero__description-group">
      <div class="methylation-hero__body" {{ body_block.shopify_attributes }}>
        {{ body_block.settings.text }}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}—— GROUP 3 · "What You Get" box (value cards) ——{%- endcomment -%}
  {%- if value_card_count > 0 -%}
    <div class="methylation-hero__value-box">
      <div class="methylation-hero__value-cards" data-card-count="{{ value_card_count }}">
        {%- for vc_block in value_card_blocks -%}
          {% render 'methylation-hero-value-card', block: vc_block %}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}—— GROUP 4 · Price + CTA ——{%- endcomment -%}
  {%- if price_block or cta_block -%}
    <div class="methylation-hero__purchase-group">
      {%- if price_block -%}
        {%- liquid
          assign compare_at  = price_block.settings.compare_at
          assign final_price = price_block.settings.final
          assign save_label  = price_block.settings.save_label
        -%}
        {%- if final_price != blank or compare_at != blank -%}
          <div class="methylation-hero__price" {{ price_block.shopify_attributes }}>
            {%- if compare_at != blank -%}
              <s class="methylation-hero__price-compare">{{ compare_at | escape }}</s>
            {%- endif -%}
            {%- if final_price != blank -%}
              <span class="methylation-hero__price-final">{{ final_price | escape }}</span>
            {%- endif -%}
            {%- if save_label != blank -%}
              <span class="methylation-hero__price-save">{{ save_label | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- if cta_block -%}
        {%- liquid
          assign cta_label = cta_block.settings.label | default: 'Claim My Bundle'
          assign cta_link  = cta_block.settings.link  | default: '#'
        -%}
        {%- if cta_label != blank -%}
          <a
            href="{{ cta_link }}"
            class="methylation-hero__cta"
            data-cta="methylation-hero"
            {{ cta_block.shopify_attributes }}
          >
            {{ cta_label | escape }}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>
  {%- endif -%}

</div>
