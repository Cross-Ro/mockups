{%- doc -%}
  Renders a single value card for the methylation-hero product copy column.

  @param {object} block - The Shopify block object (type: value_card)
{%- enddoc -%}

{%- liquid
  assign card_label  = block.settings.label
  assign card_value  = block.settings.value
  assign card_icon   = block.settings.icon
  assign card_accent = block.settings.accent
-%}

<div
  class="methylation-hero__value-card{% if card_accent != blank %} methylation-hero__value-card--accented{% endif %}"
  {% if card_accent != blank %}style="--mh-card-accent: {{ card_accent }};"{% endif %}
  {{ block.shopify_attributes }}
>
  <div class="methylation-hero__value-card-icon-box" aria-hidden="true">
    {%- if card_icon != blank -%}
      {{
        card_icon
        | image_url: width: 64
        | image_tag:
          loading: 'lazy',
          alt: '',
          class: 'methylation-hero__value-card-icon',
          widths: '32, 64'
      }}
    {%- endif -%}
  </div>

  {%- if card_label != blank -%}
    <p class="methylation-hero__value-card-label">{{ card_label | escape }}</p>
  {%- endif -%}

  {%- if card_value != blank -%}
    <p class="methylation-hero__value-card-value">{{ card_value | escape }}</p>
  {%- endif -%}
</div>
